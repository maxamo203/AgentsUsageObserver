---
import { currentRelease } from '../data/releases';
---

<section id="download" class="cta">
  <div class="container box">
    <h2>Descargalo y empezá a monitorear.</h2>
    <p>
      Instalador para Windows 10 y 11. Instalás, lo abrís y queda monitoreando
      en la bandeja del sistema.
    </p>
    <a href={currentRelease.installer} class="btn btn-primary" download>
      ⬇ Descargar v{currentRelease.version} para Windows
    </a>
    <p class="note">
      Empieza con Claude Code. Pronto, más agentes.
    </p>
  </div>
</section>

<style>
  .box {
    text-align: center;
    max-width: 640px;
  }
  h2 {
    font-size: clamp(26px, 4vw, 36px);
    font-weight: 800;
    letter-spacing: -0.02em;
  }
  p {
    color: var(--muted);
    font-size: 17px;
    margin: 16px auto 28px;
    max-width: 48ch;
  }
  .note {
    font-size: 14px;
    margin-top: 18px;
    margin-bottom: 0;
  }
  code {
    background: var(--panel);
    border: 1px solid var(--line);
    border-radius: 6px;
    padding: 1px 6px;
    font-size: 13px;
    color: var(--text);
  }
</style>
