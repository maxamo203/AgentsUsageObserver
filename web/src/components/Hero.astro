---
import { currentRelease } from "../data/releases";
---

<section id="top" class="hero">
  <div class="container grid">
    <div class="copy">
      <div class="brand">
        <img src="/logo.png" alt="" width="40" height="40" />
        <span>Agent Usage Observer</span>
      </div>
      <p class="eyebrow">Para Windows · Agentes de IA</p>
      <h1>Mira cuánto te queda de tus agentes, sin abrir nada.</h1>
      <p class="lead">
        Agent Usage Observer vive en la bandeja del sistema y te muestra tu uso
        de los límites de 5 horas y semanal de un vistazo. Empieza con Claude
        Code y sumará otros agentes —como Gemini y ChatGPT/Codex— más adelante.
      </p>
      <div class="actions">
        <a href={currentRelease.installer} class="btn btn-primary" download>
          ⬇ Descargar para Windows
        </a>
        <a href="#versions" class="btn btn-ghost">Ver versiones</a>
      </div>
      <p class="meta">
        Versión {currentRelease.version} · Para Windows 10 y 11
      </p>
    </div>

    <div class="mock" aria-hidden="true">
      <div class="panel">
        <div class="panel-head">
          <strong>Claude</strong>
          <span class="dot"></span>
          <button class="refresh" title="Actualizar" aria-label="Actualizar">
            <svg width="14" height="14" viewBox="0 0 16 16" fill="none">
              <path
                d="M 12 4 A 5 5 0 1 0 13 7.5"
                stroke="currentColor"
                stroke-width="1.6"
                stroke-linecap="round"></path>
              <path d="M 9.2 3.6 L 12.4 3.8 L 11.6 7 Z" fill="currentColor"
              ></path>
            </svg>
          </button>
        </div>

        <div class="bar-row">
          <div class="bar-label"><span>Últimas 5h</span><span>42%</span></div>
          <div class="track">
            <i style="width:42%;background:var(--green)"></i>
          </div>
          <div class="reset">Reinicia en 4h 51m</div>
        </div>

        <div class="bar-row">
          <div class="bar-label"><span>Semana</span><span>78%</span></div>
          <div class="track">
            <i style="width:78%;background:var(--yellow)"></i>
          </div>
          <div class="reset">Reinicia en 3d 19h</div>
        </div>

        <div class="panel-foot">
          <span class="muted">Actualizado 14:02:31</span>
          <span class="link">Abrir configuración ⚙</span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    border-top: none;
    padding-top: 88px;
  }
  .brand {
    display: flex;
    align-items: center;
    gap: 12px;
    font-weight: 700;
    font-size: 18px;
    margin-bottom: 28px;
  }
  .grid {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 56px;
    align-items: center;
  }
  h1 {
    font-size: clamp(32px, 5vw, 52px);
    font-weight: 800;
    letter-spacing: -0.02em;
  }
  .lead {
    font-size: 18px;
    color: var(--muted);
    margin: 20px 0 28px;
    max-width: 46ch;
  }
  .actions {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
  }
  .meta {
    margin-top: 18px;
    font-size: 13px;
    color: var(--muted);
  }

  /* Maqueta del mini panel */
  .panel {
    background: var(--panel);
    border: 1px solid var(--line);
    border-radius: 14px;
    padding: 20px;
    box-shadow: 0 16px 40px rgba(0, 0, 0, 0.4);
  }
  .panel-head {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 18px;
  }
  .panel-head strong {
    font-size: 15px;
  }
  .panel-head .status {
    margin-left: auto;
    color: var(--muted);
    font-size: 12px;
  }
  .refresh {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 22px;
    height: 22px;
    padding: 0;
    border: 0;
    border-radius: 6px;
    background: transparent;
    color: var(--muted);
    cursor: pointer;
  }
  .refresh:hover {
    background: #2a2c34;
    color: var(--text);
  }
  .refresh:hover svg {
    animation: spin 0.8s linear infinite;
  }
  @keyframes spin {
    to {
      transform: rotate(360deg);
    }
  }
  .dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--green);
  }
  .muted {
    color: var(--muted);
    font-size: 12px;
  }
  .bar-row {
    margin-bottom: 18px;
  }
  .bar-label {
    display: flex;
    justify-content: space-between;
    font-size: 13px;
    margin-bottom: 6px;
  }
  .track {
    height: 8px;
    background: #14151a;
    border-radius: 99px;
    overflow: hidden;
  }
  .track i {
    display: block;
    height: 100%;
    border-radius: 99px;
  }
  .reset {
    color: var(--muted);
    font-size: 11px;
    margin-top: 6px;
  }
  .panel-foot {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 14px;
  }
  .panel-foot .link {
    color: var(--blue);
    font-size: 12px;
  }

  @media (max-width: 860px) {
    .grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }
  }
</style>
