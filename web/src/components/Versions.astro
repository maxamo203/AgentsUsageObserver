---
import { releases } from '../data/releases';

const typeLabel: Record<string, string> = {
  new: 'Nuevo',
  fix: 'Arreglo',
  change: 'Cambio',
};
const typeColor: Record<string, string> = {
  new: 'var(--green)',
  fix: 'var(--red)',
  change: 'var(--blue)',
};
---

<section id="versions">
  <div class="container">
    <p class="eyebrow">Historial</p>
    <h2>Versiones y cambios.</h2>

    <div class="list">
      {releases.map((r) => (
        <article class="card release">
          <div class="head">
            <div class="ver">
              <h3>v{r.version}</h3>
              {r.current && <span class="badge">Actual</span>}
            </div>
            <time>{r.date}</time>
          </div>

          <ul class="changes">
            {r.changes.map((c) => (
              <li>
                <span class="type" style={`color:${typeColor[c.type]};border-color:${typeColor[c.type]}`}>
                  {typeLabel[c.type]}
                </span>
                <span>{c.text}</span>
              </li>
            ))}
          </ul>

          <a href={r.installer} class="btn btn-ghost dl" download>
            ⬇ Descargar v{r.version}
          </a>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  h2 {
    font-size: clamp(26px, 4vw, 36px);
    font-weight: 800;
    letter-spacing: -0.02em;
    margin-bottom: 36px;
  }
  .list {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }
  .head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 18px;
  }
  .ver {
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .ver h3 {
    font-size: 22px;
  }
  .badge {
    font-size: 12px;
    font-weight: 700;
    color: var(--ink);
    background: var(--yellow);
    padding: 3px 10px;
    border-radius: 99px;
  }
  time {
    color: var(--muted);
    font-size: 14px;
  }
  .changes {
    list-style: none;
    margin: 0 0 20px;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .changes li {
    display: flex;
    align-items: baseline;
    gap: 12px;
    font-size: 15px;
  }
  .type {
    flex: none;
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    border: 1px solid;
    border-radius: 99px;
    padding: 2px 9px;
    min-width: 64px;
    text-align: center;
  }
  .dl {
    font-size: 14px;
    padding: 10px 18px;
  }
</style>
