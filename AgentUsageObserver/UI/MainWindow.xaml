<Window x:Class="AgentUsageObserver.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:AgentUsageObserver.Services.Localization"
        Title="{loc:Tr WindowConfigTitle}"
        Icon="/logo.ico"
        Width="460" Height="520"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E24"
        ResizeMode="CanMinimize">
    <Window.Resources>
        <Style TargetType="TextBlock" x:Key="Label">
            <Setter Property="Foreground" Value="#C9CDD4"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
        <Style TargetType="TextBlock" x:Key="Section">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>
        <Style TargetType="TextBlock" x:Key="Hint">
            <Setter Property="Foreground" Value="#6E7681"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0,2,0,0"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="{loc:Tr SettingsHeader}"
                   Foreground="White"
                   FontSize="20"
                   FontWeight="Bold"
                   Margin="0,0,0,16"/>

        <StackPanel Grid.Row="1">
            <!-- Intervalo de sondeo -->
            <TextBlock Style="{StaticResource Section}" Text="{loc:Tr SectionRefresh}"/>
            <TextBlock Style="{StaticResource Label}">
                <Run Text="{loc:Tr PollIntervalLabel}"/>
                <Run x:Name="IntervalValueText" Text="300 s" FontWeight="SemiBold" Foreground="White"/>
            </TextBlock>
            <Slider x:Name="IntervalSlider"
                    Minimum="60" Maximum="900"
                    TickFrequency="60" IsSnapToTickEnabled="True"
                    ValueChanged="OnIntervalChanged"/>
            <TextBlock Style="{StaticResource Hint}"
                       Text="{loc:Tr PollIntervalHint}"/>

            <!-- Umbrales de color -->
            <TextBlock Style="{StaticResource Section}" Text="{loc:Tr SectionIconColors}" Margin="0,20,0,10"/>

            <CheckBox x:Name="UseServerSeverityCheck"
                      Foreground="#C9CDD4"
                      Content="{loc:Tr UseServerSeverity}"
                      Checked="OnUseServerSeverityToggled"
                      Unchecked="OnUseServerSeverityToggled"/>
            <TextBlock Style="{StaticResource Hint}"
                       Text="{loc:Tr UseServerSeverityHint}"/>

            <StackPanel x:Name="ThresholdsPanel" Margin="0,12,0,0">
                <TextBlock Style="{StaticResource Label}">
                    <Run Text="{loc:Tr WarnFromLabel}"/>
                    <Run x:Name="WarnValueText" Text="70 %" FontWeight="SemiBold" Foreground="#D29922"/>
                </TextBlock>
                <Slider x:Name="WarnSlider" Minimum="1" Maximum="99"
                        ValueChanged="OnWarnChanged"/>

                <TextBlock Style="{StaticResource Label}" Margin="0,12,0,4">
                    <Run Text="{loc:Tr CritFromLabel}"/>
                    <Run x:Name="CritValueText" Text="90 %" FontWeight="SemiBold" Foreground="#DA3633"/>
                </TextBlock>
                <Slider x:Name="CritSlider" Minimum="2" Maximum="100"
                        ValueChanged="OnCritChanged"/>
            </StackPanel>

            <!-- Inicio -->
            <TextBlock Style="{StaticResource Section}" Text="{loc:Tr SectionSystem}" Margin="0,20,0,10"/>
            <CheckBox x:Name="StartupCheck"
                      Foreground="#C9CDD4"
                      Content="{loc:Tr StartWithWindows}"/>
        </StackPanel>

        <!-- Botones -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="{loc:Tr ButtonClose}" Width="90" Height="32" Margin="0,0,8,0" Click="OnCloseClick"/>
            <Button Content="{loc:Tr ButtonSave}" Width="110" Height="32" Click="OnSaveClick"
                    Background="#2EA043" Foreground="White" BorderThickness="0"/>
        </StackPanel>
    </Grid>
</Window>
